{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "mysuperposition",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Create a new post",
        "description": "mysuperposition",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "Example form",
        "description": "Show a simple form",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/example-form"
      },
      {
        "label": "Generate market review draft",
        "description": "Build draft from approved source signal sweep",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-market-review-draft"
      },
      {
        "label": "Approve latest market review draft",
        "description": "Move latest draft to approved stage",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-market-review-approve"
      },
      {
        "label": "Post approved market review",
        "description": "Publish approved draft subject to throttle",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-market-review"
      }
    ]
  },
  "forms": {
    "exampleForm": "/internal/form/example-submit"
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "mysuperposition_dev"
  }
}